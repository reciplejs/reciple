{
  "$schema": "https://raw.githubusercontent.com/SchemaStore/schemastore/master/src/schemas/json/nodemon.json",
  "restartable": "r",
  "ext": "js,jsx,ts,tsx,json",
  "signal": "SIGHUP",
  "watch": [
    "src",
    "reciple.config.js",
    "reciple.config.ts",
    "package.json",
    ".env"
  ],
  "env": {
    "NODE_OPTIONS": "--enable-source-maps"
  },
  "exec": "reciple start --build"
}